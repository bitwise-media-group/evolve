.SH NAME
evolve-run-evals - Run Tier 2 behavioral evals: agent sessions graded by assertions


.SH SYNOPSIS
\fBevolve run evals [flags]\fP


.SH DESCRIPTION
Run Tier 2 behavioral evals: agent sessions graded by assertions


.SH OPTIONS
\fB--count-only\fP[=false]
	skip agent runs; only compute token usage per model

.PP
\fB--eval\fP=""
	only run the eval with this id

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for evals

.PP
\fB--jobs\fP=4
	concurrent agent runs (default: ceil(cpus/2))

.PP
\fB--judge-model\fP="claude-sonnet-4-6"
	claude model that grades llm assertions

.PP
\fB--keep-workspaces\fP[=false]
	keep throwaway workspaces for debugging

.PP
\fB--models\fP=""
	comma-separated provider names / model ids, or "all" (default: config default_models or "anthropic")

.PP
\fB--new\fP[=false]
	only run evals whose stored results are missing values a rerun could fill

.PP
\fB--skill\fP=""
	only run evals for this skill

.PP
\fB--timeout\fP=600
	seconds per agent run


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--json\fP[=false]
	emit machine-readable JSONL progress on stdout

.PP
\fB--layout\fP="auto"
	repository layout: auto, marketplace, multi, or single

.PP
\fB--results-format\fP=""
	format for results files and the EVALUATION rollup: json, jsonc, or yaml (default: config results_format or json)

.PP
\fB--root\fP=""
	repository root to operate on (default: walk up from the current directory)

.PP
\fB--strict\fP[=false]
	exit 1 when checks or evals fail (default: warn and exit 0)

.PP
\fB-v\fP, \fB--verbose\fP[=false]
	enable debug logging



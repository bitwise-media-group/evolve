{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/bitwise-media-group/evolve/main/schemas/timing.schema.json",
  "title": "timing.json (skill-creator superset)",
  "description": "Wall-clock and token timing for one run, compatible with skill-creator's timing.json. Evolve populates executor_duration_seconds (the agent run; grading excluded) and total_tokens; the grader fields await grading instrumentation.",
  "type": "object",
  "properties": {
    "$schema": { "type": "string" },
    "total_tokens": { "type": "integer", "minimum": 0 },
    "duration_ms": { "type": "integer", "minimum": 0 },
    "total_duration_seconds": { "type": "number", "minimum": 0 },
    "executor_start": { "type": "string", "format": "date-time" },
    "executor_end": { "type": "string", "format": "date-time" },
    "executor_duration_seconds": { "type": "number", "minimum": 0 },
    "grader_start": { "type": "string", "format": "date-time" },
    "grader_end": { "type": "string", "format": "date-time" },
    "grader_duration_seconds": { "type": "number", "minimum": 0 }
  },
  "additionalProperties": true
}
